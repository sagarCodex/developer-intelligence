generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes         Note[]
  snippets      Snippet[]
  tasks         Task[]
  projects      Project[]
  focusSessions FocusSession[]
  dailyLogs     DailyLog[]
  stats         Stat[]
  settings      Settings?

  @@map("users")
}

// ─── Project ───────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("#00E5C8")
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes    Note[]
  snippets Snippet[]
  tasks    Task[]

  @@map("projects")
}

// ─── Note ──────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  title     String
  content   String   @default("")
  isPinned  Boolean  @default(false)
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@map("notes")
}

// ─── Snippet ───────────────────────────────────────────

model Snippet {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  language    String
  code        String
  description String?
  tags        String[]
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, language])
  @@map("snippets")
}

// ─── Task ──────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("tasks")
}

// ─── Focus Session ─────────────────────────────────────

enum FocusType {
  DEEP_WORK
  SHALLOW_WORK
  LEARNING
  BREAK
}

model FocusSession {
  id        String    @id @default(cuid())
  userId    String
  duration  Int // seconds
  type      FocusType @default(DEEP_WORK)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("focus_sessions")
}

// ─── Daily Log ─────────────────────────────────────────

enum Mood {
  GREAT
  GOOD
  OKAY
  BAD
  TERRIBLE
}

model DailyLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  mood        Mood?
  energyLevel Int?     @default(3)
  summary     String?
  wins        String[]
  blockers    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_logs")
}

// ─── Stats ─────────────────────────────────────────────

model Stat {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  focusMinutes   Int      @default(0)
  tasksCompleted Int      @default(0)
  notesCreated   Int      @default(0)
  snippetsSaved  Int      @default(0)
  streakDays     Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("stats")
}

// ─── Settings ──────────────────────────────────────────

model Settings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  theme                String  @default("dark")
  focusDuration        Int     @default(1500) // 25 min in seconds
  breakDuration        Int     @default(300) // 5 min in seconds
  dailyGoalMinutes     Int     @default(240) // 4 hours
  notificationsEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}
